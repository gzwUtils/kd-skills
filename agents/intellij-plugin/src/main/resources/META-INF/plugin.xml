<idea-plugin>
    <id>com.kd.skills.agent</id>
    <name>KD Skills Agent</name>
    <vendor>KD Skills</vendor>

    <description>
        Commit-time AI review based on your local SKILL.md guidelines.
    </description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>

    <extensions defaultExtensionNs="com.intellij">
        <checkinHandlerFactory implementation="com.kd.skills.agent.vcs.KdSkillsCheckinHandlerFactory" />
        <projectConfigurable
                id="com.kd.skills.agent.settings"
                displayName="KD Skills Agent"
                instance="com.kd.skills.agent.settings.KdSkillsSettingsConfigurable" />
    </extensions>
</idea-plugin>
